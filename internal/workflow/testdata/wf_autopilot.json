{
  "nodes": [
    { "id": "START" },
    {
      "id": "plan",
      "displayName": "规划",
      "engine": "claude-code",
      "promptTemplate": "{{sys.userPrompt}}"
    },
    {
      "id": "code",
      "displayName": "编码",
      "engine": "claude-code",
      "promptTemplate": "基于规划实现：\n{{plan}}"
    },
    {
      "id": "test",
      "displayName": "测试",
      "engine": "antigravity",
      "promptTemplate": "为下面的规划编写测试：\n{{plan}}"
    },
    {
      "id": "review",
      "displayName": "评审",
      "engine": "claude-code",
      "promptTemplate": "评审实现与测试：\n{{code}}\n{{test}}"
    },
    { "id": "END" }
  ],
  "edges": [
    { "from": "START", "to": "plan" },
    { "from": "plan", "to": "code" },
    { "from": "plan", "to": "test" },
    { "from": "code", "to": "review" },
    { "from": "test", "to": "review" },
    { "from": "review", "to": "END" }
  ]
}
